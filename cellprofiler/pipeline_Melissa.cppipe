Watershed:[module_num:11|svn_version:'Unknown'|variable_revision_number:3|show_window:True|notes:['This module implements the watershed algorithm which will segment the nuclei. Essentially this involves finding the center of the spheres we thresholded in the last step, looking for the pixels with the furthest distance from the edge, calling them centers, then expanding out from the centers until all thresholded pixels have been added to one object or another.  See http://scikit-image.org/docs/dev/auto_examples/segmentation/plot_watershed.html for more information.']|batch_state:array([], dtype=uint8)|enabled:False|wants_pause:False]
