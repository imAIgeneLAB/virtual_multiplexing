Resize:[module_num:5|svn_version:'Unknown'|variable_revision_number:5|show_window:False|notes:['Processing 3D images requires much more computation time than 2D images. Often, downsampling an image can yield large performance gains and at the same time smooth an image to remove noise. If the objects of interest are relatively large compared to the pixel size, then downsampling will only minimally affect the final segmentation.  This module will resize the nuclei image.']|batch_state:array([], dtype=uint8)|enabled:True|wants_pause:False]
