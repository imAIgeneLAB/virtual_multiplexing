GaussianFilter:[module_num:7|svn_version:'Unknown'|variable_revision_number:1|show_window:True|notes:['A Gaussian filter will reduce noise by blurring the image and is useful when the foreground signal is noisy. Ideal tuning at this step helps prevent oversegmentation but will not cause undersegmentation of the nuclei.  A filter window size of 2 is chosen.']|batch_state:array([], dtype=uint8)|enabled:False|wants_pause:False]
